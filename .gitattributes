# Auto-detect text files and normalise to LF in the repo.
* text=auto eol=lf

# Windows-only scripts keep CRLF.
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Binary assets — do not touch.
*.png  binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.woff binary
*.woff2 binary
*.zip  binary
*.tar  binary
*.gz   binary
*.wsl  binary
